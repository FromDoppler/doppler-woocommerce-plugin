#: admin/class-doppler-for-woocommerce-admin.php:152
#: admin/class-doppler-for-woocommerce-admin.php:166
#: admin/class-doppler-for-woocommerce-admin.php:187
msgid "Got it"
msgstr "Entendido"

#: admin/class-doppler-for-woocommerce-admin.php:236
msgid "Ouch! Enter a valid Email."
msgstr "¡Ouch! Escribe un Email válido."

#: admin/class-doppler-for-woocommerce-admin.php:237
msgid "Ouch! The Field is empty."
msgstr "¡Ouch! El campo está vacío."

#: admin/class-doppler-for-woocommerce-admin.php:238
msgid ""
"Ouch! There's something wrong with your Username or API Key. Please, try "
"again."
msgstr "¡Ouch! Hay un error en tu Usuario o API Key. Vuelve a intentarlo."

#: admin/class-doppler-for-woocommerce-admin.php:239
msgid "The List has been created correctly."
msgstr "La Lista se ha creado correctamente."

#: admin/class-doppler-for-woocommerce-admin.php:240
msgid "Ouch! You've reached the maximum number of Lists created."
msgstr "¡Ouch! Has alcanzado el número máximo de Listas creadas."

#: admin/class-doppler-for-woocommerce-admin.php:241
msgid "Ouch! You've already used this name for another List."
msgstr "¡Ouch! Ya has utilizado este nombre para otra Lista."

#: admin/class-doppler-for-woocommerce-admin.php:242
msgid ""
"Ouch! You've made several actions in a short period of time. Please wait a "
"few minutes before making another one."
msgstr ""
"¡Ouch! Has realizado varias acciones en un periodo corto de tiempo. Por "
"favor, espera unos minutos antes de realizar otra."

#: admin/class-doppler-for-woocommerce-admin.php:243
msgid "Ouch! List name is invalid. Please choose another name."
msgstr "¡Ouch! El nombre de la Lista es inválido. Elige otro nombre."

#: admin/class-doppler-for-woocommerce-admin.php:244
msgid "Save"
msgstr "Guardar"

#: admin/class-doppler-for-woocommerce-admin.php:245
msgid "Cancel"
msgstr "Cancelar"

#: admin/class-doppler-for-woocommerce-admin.php:246
msgid "Ouch! The Lists couldn't be synchronized."
msgstr "¡Ouch! La lista no se pudo sincronizar."

#: admin/class-doppler-for-woocommerce-admin.php:247
msgid "Your Lists has been syncronized and saved succesfully."
msgstr "Tus Listas fueron sincronizadas y guardadas con éxito."

#: admin/class-doppler-for-woocommerce-admin.php:248
msgid "We're synchronizing your Customers with your Doppler List..."
msgstr "Estamos sincronizando tus Clientes con tus Listas de Doppler."

#: admin/class-doppler-for-woocommerce-admin.php:249
msgid ""
"Select the Doppler Lists where you want to import your Customers. When "
"synchronized, those Customers already registered and future customers will "
"be sent automatically."
msgstr ""
"Selecciona las Listas de Doppler a donde quieres importar tus Clientes. Al "
"sincronizarlas, se enviarán automáticamente los existentes y los futuros "
"clientes."

#: admin/class-doppler-for-woocommerce-admin.php:250
#: admin/partials/lists.php:20 admin/partials/lists.php:75
msgid "WooCommerce Buyers"
msgstr "Compradores de WooCommerce"

